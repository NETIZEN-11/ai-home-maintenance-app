# Production Environment Variables for Render
# Copy this file to .env and fill in the values, OR set these in Render Dashboard

# MongoDB Atlas Connection String (Required)
# Get free tier at: https://www.mongodb.com/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai-hma?retryWrites=true&w=majority

# JWT Secret (Required) - Must be at least 32 characters
JWT_SECRET=your-super-secret-production-key-at-least-32-characters-long

# Gemini API Key (Optional) - Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Server Port (Render sets this automatically)
PORT=10000

# Node Environment
NODE_ENV=production
